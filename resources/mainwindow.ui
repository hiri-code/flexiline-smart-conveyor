	font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
}

/*Default styles of &quot;cards&quot;*/
QFrame#camera_card, 
QFrame#controls_card, 
QFrame#chart_card, 
QFrame#counters_card {
